# =============================================
# Database (Neon Postgres)
# Lấy từ: Vercel → Project → Storage → Neon
# Hoặc: vercel env pull .env.local
# =============================================
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# =============================================
# NextAuth v5 — Auth.js
# Tạo secret ngẫu nhiên: openssl rand -base64 33
# =============================================
AUTH_SECRET=your-very-strong-random-secret-here

# =============================================
# Google OAuth (tuỳ chọn — bỏ trống nếu chỉ dùng email/mật khẩu)
# Tạo tại: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://your-app.vercel.app/api/auth/callback/google
# =============================================
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
