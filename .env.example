# Kết nối Postgres (Neon) — lấy từ Vercel: Project → Storage → Connect a Database → Neon.
# Sau khi kết nối, chạy `vercel env pull .env.local` để tải biến này về máy,
# hoặc dán connection string từ Neon dashboard vào đây và đổi tên file thành .env.local
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
